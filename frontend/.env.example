# Backend API base URL. Set this to your deployed backend origin when running on
# a real device or production deployment (e.g. https://api.yourapp.com).
# Leave blank to fall back to http://localhost:8000 for local dev.
VITE_API_BASE_URL=

# Google Maps JavaScript API key — powers the delivery-location confirmation map.
# Create one at https://console.cloud.google.com/google/maps-apis/credentials
# Enable "Maps JavaScript API" and "Geocoding API", and add HTTP referrer
# restrictions for your domain. Then copy this file to `.env` and paste the key.
VITE_GOOGLE_MAPS_API_KEY=
